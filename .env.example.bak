# Local Python runtime config.
# Copy to .env and adjust for your environment.

BF6_DB_PATH=data/bf6_stats.db
BF6_CORS_ORIGINS=any
BF6_SUSPICION_CORS_ORIGIN=

BF6_REPORTER_COOKIE_SECURE=false
BF6_REPORTER_COOKIE_SAMESITE=lax
BF6_REPORTER_COOKIE_SECRET=change-me-for-any-shared-environment

BF6_POLL_ENABLED=true
BF6_POLL_INTERVAL_SECONDS=300
BF6_POLL_BATCH_SIZE=20
BF6_POLL_BATCH_WORKERS=4
BF6_POLL_PROFILE_WORKERS=4
BF6_POLL_STAGGER_SECONDS=0.0
BF6_POLL_LOG_BATCH_SUCCESS=false

BF6_TRACKED_COUNTS_ENABLED=true
BF6_TRACKED_COUNTS_INTERVAL_SECONDS=900

TZ=Europe/London
